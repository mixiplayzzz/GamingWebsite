<!DOCTYPE html>
<html>
<head>
<title>BGMI HUD Settings</title>

<style>
body{
    background:#0b0b0b;
    color:white;
    font-family:Arial;
    text-align:center;
}

h1{
    color:#00e5ff;
}

.card{
    background:#171717;
    margin:15px auto;
    padding:20px;
    width:80%;
    border-radius:15px;
    box-shadow:0 0 15px #00e5ff;
}

a{
    display:block;
    margin:15px auto;
    width:80%;
    padding:18px;

    background:rgba(0,0,0,0.7);
    border:2px solid #00e5ff;
    border-radius:15px;

    color:white;
    text-decoration:none;
    font-size:22px;
    font-weight:bold;

    box-shadow:0 0 15px #00e5ff;
    transition:0.3s;
}

a:hover{
    background:#00e5ff;
    color:black;
    transform:scale(1.05);
}

a:hover{
    background:#00e5ff;
    color:black;
}
</style>

</head>

<body>

<h1>🎮 BGMI HUD Settings</h1>

<div class="card">
<a href="/hud/2">🔥 2 Finger HUD</a>
<a href="/hud/3">🔥 3 Finger HUD</a>
<a href="/hud/4">🔥 4 Finger HUD</a>
<a href="/hud/5">🔥 5 Finger HUD</a>
</div>

</body>
</html>
<!DOCTYPE html>
<html>
<head>
<title>MiXi PlayzZz Gaming</title>

<style>
body{
    margin:0;
    background:#0b0b0b;
    color:white;
    font-family:Arial;
    text-align:center;
}

.header{
    padding:40px 10px;
}

h1{
    color:#00e5ff;
    font-size:40px;
    text-shadow:0 0 15px #00e5ff;
}

p{
    color:#ccc;
    font-size:18px;
}

.card{
    background:#171717;
    width:85%;
    margin:20px auto;
    padding:25px;
    border-radius:20px;
    box-shadow:0 0 20px #00e5ff;
}

.btn{
    display:block;
    margin:15px;
    padding:15px;
    background:#111;
    border:2px solid #00e5ff;
    border-radius:15px;
    color:white;
    text-decoration:none;
    font-size:22px;
}

.btn:hover{
    background:#00e5ff;
    color:black;
}

</style>

</head>

<body>

<div class="header">
<img src="/static/images/mixi_logo.png" width="180">
<h1>🎮 MiXi PlayzZz</h1>

<p>BGMI HUD & Sensitivity Settings</p>

</div>


<div class="card">

<a class="btn" href="/hud">🔥 HUD Settings</a>

<a class="btn" href="/sensitivity">🎯 Sensitivity Settings</a>

</div>

</body>
</html>